        {
          "name": "Buscar por Turma e Data",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/frequencia/turma/:turma_id/data/:data_aula?disciplina_id=",
              "host": ["{{baseUrl}}"],
              "path": ["frequencia", "turma", ":turma_id", "data", ":data_aula"],
              "query": [
                {
                  "key": "disciplina_id",
                  "value": "",
                  "description": "Opcional: Filtrar por disciplina",
                  "disabled": true
                }
              ],
              "variable": [
                {
                  "key": "turma_id",
                  "value": "{{turma_id}}"
                },
                {
                  "key": "data_aula",
                  "value": "{{data_aula}}"
                }
              ]
            },
            "description": "Busca frequências por turma e data.\n\n**Query Params Opcionais**:\n- disciplina_id: Filtrar por disciplina específica\n\n**Permissões**: ADMIN, SECRETARIO, PROFESSOR"
          },
          "response": []
        },
        {
          "name": "⚠️ Buscar por Data e Vinculação (DEPRECATED)",
          "request": {
            "method": "GET",
            "header": [],
