            "url": {
              "raw": "{{baseUrl}}/frequencia/detalhes/:frequencia_id",
              "host": ["{{baseUrl}}"],
              "path": ["frequencia", "detalhes", ":frequencia_id"],
              "variable": [
                {
                  "key": "frequencia_id",
