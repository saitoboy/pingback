              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"presenca\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/frequencia/:frequencia_id",
              "host": ["{{baseUrl}}"],
              "path": ["frequencia", ":frequencia_id"],
              "variable": [
                {
                  "key": "frequencia_id",
                  "value": "{{frequencia_id}}"
                }
              ]
            },
            "description": "Atualiza uma frequência existente.\n\n**Body**:\n```json\n{\n  \"presenca\": false\n}\n```\n\n**Permissões**: ADMIN, SECRETARIO, PROFESSOR"
          },
          "response": []
        }
      ]
    },
    {
      "name": "🗑️ 5. Deletar Frequências",
      "item": [
        {
          "name": "Deletar Frequência",
          "request": {
            "method": "DELETE",
            "header": [],
