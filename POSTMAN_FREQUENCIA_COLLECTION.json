              ]
            },
            "description": "Busca uma frequência específica com todos os detalhes.\n\n**Permissões**: ADMIN, SECRETARIO, PROFESSOR"
          },
          "response": []
        },
        {
          "name": "✅ Buscar por Professor, Turma e Data (NOVO - Recomendado)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/frequencia/professor/:professor_id/turma/:turma_id/data/:data",
              "host": ["{{baseUrl}}"],
              "path": ["frequencia", "professor", ":professor_id", "turma", ":turma_id", "data", ":data"],
              "variable": [
                {
                  "key": "professor_id",
                  "value": "{{professor_id}}"
                },
                {
                  "key": "turma_id",
                  "value": "{{turma_id}}"
                },
                {
                  "key": "data",
                  "value": "{{data_aula}}"
                }
              ]
            },
            "description": "**MÉTODO PRINCIPAL** - Busca frequências por professor, turma e data.\n\nEste é o método recomendado pois não depende de disciplina ou aula criada.\n\n**Parâmetros**:\n- professor_id: UUID do professor\n- turma_id: UUID da turma\n- data: Data no formato YYYY-MM-DD\n\n**Retorna**: Lista de frequências com dados do aluno (nome, RA, presença)\n\n**Permissões**: ADMIN, SECRETARIO, PROFESSOR"
          },
          "response": []
        },
        {
          "name": "Buscar por Matrícula",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/frequencia/matricula/:matricula_aluno_id",
              "host": ["{{baseUrl}}"],
              "path": ["frequencia", "matricula", ":matricula_aluno_id"],
              "variable": [
                {
                  "key": "matricula_aluno_id",
                  "value": "{{matricula_aluno_id}}"
                }
              ]
            },
            "description": "Busca todas as frequências de uma matrícula específica.\n\n**Permissões**: ADMIN, SECRETARIO, PROFESSOR"
          },
          "response": []
        },
        {
          "name": "Buscar por Aluno",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/frequencia/aluno/:aluno_id",
              "host": ["{{baseUrl}}"],
              "path": ["frequencia", "aluno", ":aluno_id"],
              "variable": [
                {
                  "key": "aluno_id",
                  "value": "{{aluno_id}}"
                }
              ]
            },
            "description": "Busca todas as frequências de um aluno específico.\n\nRetorna frequências com dados da disciplina, turma e aula.\n\n**Permissões**: ADMIN, SECRETARIO, PROFESSOR"
          },
          "response": []
        },
        {
          "name": "Buscar por Aula",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/frequencia/aula/:aula_id",
              "host": ["{{baseUrl}}"],
              "path": ["frequencia", "aula", ":aula_id"],
              "variable": [
