              "raw": "{{baseUrl}}/frequencia/estatisticas/aluno/:aluno_id",
              "host": ["{{baseUrl}}"],
              "path": ["frequencia", "estatisticas", "aluno", ":aluno_id"],
              "variable": [
                {
