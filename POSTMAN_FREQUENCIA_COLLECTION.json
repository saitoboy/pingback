              "path": ["frequencia", ":frequencia_id"],
              "variable": [
                {
                  "key": "frequencia_id",
                  "value": "{{frequencia_id}}"
                }
              ]
            },
            "description": "Deleta uma frequência específica.\n\n**Permissões**: ADMIN, SECRETARIO apenas"
          },
          "response": []
        }
      ]
    },
    {
      "name": "📊 6. Estatísticas",
      "item": [
