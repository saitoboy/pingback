            "header": [],
            "url": {
              "raw": "{{baseUrl}}/frequencia/estatisticas/turma/:turma_id/disciplina/:disciplina_id?data_inicio=&data_fim=",
              "host": ["{{baseUrl}}"],
              "path": ["frequencia", "estatisticas", "turma", ":turma_id", "disciplina", ":disciplina_id"],
              "query": [
                {
                  "key": "data_inicio",
                  "value": "",
